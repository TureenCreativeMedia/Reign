--- !u!114 &1042509759720609901
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6419290268535131545}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 49570b694e1bd204489e5e5f5696e3ec, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  comment: "---------------------------------------\n\n=-- Reign | \xA9 Purple Swing
    --=\n\nThe solution to all problems when starting an ambitious Unity project.
    Countless systems working asynchronously to perform as well as possible, even
    on low-end devices, to make creating great games simple.\n\n---------------------------------------"
--- !u!114 &6634572504446025252
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6419290268535131545}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 49570b694e1bd204489e5e5f5696e3ec, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  comment: "             REIGN v1.0.0.0\n---------------------------------------\n\n=----------
    CHANGELOG ----------=\n\n- Recreated Reign from scratch for the final time\n\n-
    Changed scripting backend from Mono to IL2CPP\n\n- Made Audio System capable
    of using multiple clips per entry and playing one index when using any Play()
    function\n\n- Made SaveSystem asynchronous to avoid long stutters between saving
    and loading\n\n- Added InputMap which contains input dictionary and helper functions
    for overriding and saving keybinds\n\n- Made InputSystem and SaveSystem contain
    InputMap class \n- Optimised DiscordSystem to reduce update calls\n\n- Input
    map standard is now lowercase IDs opposed to camelcase in previous Reign versions\n\n-
    Moved all app configuration to GameCertificates.cs opposed to AppData scriptable
    object from previous Reign versions\n\n- Audio system now uses a master mixer
    channel by default, and assigns to the exposed volume parameter in LoadData()\n\n-
    Added lots of useful utility functions to ReignUtils.cs\n"
